<!DOCTYPE html>
<html lang="en">
<head>
   <title>Alert Lab Computational Thinking | University of Alberta</title>
   <meta name="viewport" content="width=device-width, user-scalable=yes">

   <script type="text/javascript" src="<%= javascript_path('javascripts/web-main') %>"></script>

   <link rel="stylesheet" href="<%= stylesheet_path('styles/admin-main') %>">

   <script src="https://cdnjs.cloudflare.com/ajax/libs/zxcvbn/4.4.2/zxcvbn.js"
           integrity="sha256-Znf8FdJF85f1LV0JmPOob5qudSrns8pLPZ6qkd/+F0o="
           crossorigin="anonymous"></script>

   <script>
      window.appData = {};
      window.appData.imagePaths = {
         person: '<%= image_path('images/person.svg') %>',
         people: '<%= image_path('images/people.svg') %>',
         eyeGrey: '<%= image_path('images/eye-grey.svg') %>'
      };

      window.appData.roles = '<%= Addressable::URI::escape(settings.container.persisters[:user].roles.to_a.collect do |r|
         r.name.downcase
      end.to_s) %>';
   </script>
</head>
<body>

<header class="page-header">
   <a href="/admin/people" class="banner">
      <div class="logo">
         <img src="<%= image_path('images/logos/UA-COLOUR-440px.png') %> " alt="U of A Logo" title="Admin Home">
         <span>Alert Lab</span>
      </div>

      <span class="subtitle">Computational Thinking Experiments</span>
   </a>

   <nav class="main-nav">
      <navigation-menu params="options: {
                                 People: {url: '/admin/people', icon: window.appData.imagePaths.person},
                                 Groups: {url: '/admin/groups', icon: window.appData.imagePaths.people},
                                 'session': {tag: '<current-session></current-session>'}
                               }">
      </navigation-menu>
   </nav>

   <info-toast params="notices: window.toasts.info, warning: window.toasts.warn, errors: window.toasts.error"></info-toast>
</header>

<main>
   <%= yield %>

   <div class="game-container"></div>
</main>

<%
   templates = Pathname.glob('./faces/web/assets/components/**/*.html').sort_by(&:basename)

   templates.each do |template_file| %>
   <template id="<%= template_file.basename(template_file.extname) %>-template" style="display: none;">
      <%
         content = File.read(template_file)
         # path and line needed to work around Sinatra Namespace bug
         rendered = render :html,
                           content,
                           path:   template_file.expand_path,
                           line:   1,
                           locals: {container: settings.container}
      %>
      <%= rendered %>
   </template>
<% end %>

</body>
</html>
